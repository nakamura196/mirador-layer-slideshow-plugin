{
  "name": "mirador-layer-slideshow",
  "version": "1.0.0",
  "description": "A Mirador 4 plugin that adds a layer slideshow to the OpenSeadragon viewer",
  "type": "module",
  "main": "./dist/mirador-layer-slideshow.es.js",
  "module": "./src/index.jsx",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./src": "./src/index.jsx",
    ".": {
      "import": "./dist/mirador-layer-slideshow.es.js"
    }
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "build:demo": "vite build --config vite.demo.config.js"
  },
  "peerDependencies": {
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "mirador": "^4.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-i18next": "^13.0.0 || ^14.0.0 || ^15.0.0"
  },
  "devDependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^7.0.0",
    "@mui/material": "^7.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "mirador": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.0.0",
    "vite": "^6.0.0"
  },
  "author": "",
  "homepage": "https://github.com/nakamura196/mirador-layer-slideshow-plugin",
  "license": "Apache-2.0",
  "repository": "github:nakamura196/mirador-layer-slideshow-plugin",
  "keywords": [
    "mirador",
    "iiif",
    "plugin",
    "layer",
    "slideshow"
  ]
}
